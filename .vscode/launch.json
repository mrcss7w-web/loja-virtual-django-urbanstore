{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "▶ Rodar Django",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": ["runserver"],
      "django": true,
      "justMyCode": true,
      "env": {
        "DJANGO_SETTINGS_MODULE": "loja_virtual.settings"
      }
    },
    {
      "name": "🧪 Rodar Testes",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/manage.py",
      "args": ["test", "--verbosity=2"],
      "django": true,
      "justMyCode": true
    }
  ]
}
